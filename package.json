{
  "name": "convex-monorepo",
  "private": true,
  "packageManager": "npm@10.8.2",
  "scripts": {
    "dev": "turbo run dev",
    "ios": "npm run ios --workspace=native",
    "android": "npm run android --workspace=native",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "3.7.4",
    "turbo": "2.6.2",
    "react-native": "0.81.5",
    "react": "19.1.0",
    "tailwindcss": "^3.4.0",
    "nativewind": "4.1.23",
    "lightningcss": "1.27.0",
    "@clerk/clerk-react": "5.57.1",
    "convex": "^1.19.1"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "resolutions": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16"
  }
}
